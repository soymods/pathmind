{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Minecraft Client (:fabric)",
      "preLaunchTask": "fabric: classes",
      "request": "launch",
      "cwd": "${workspaceFolder}/fabric\\run",
      "console": "integratedTerminal",
      "stopOnEntry": false,
      "mainClass": "dev.architectury.transformer.TransformerRuntime",
      "vmArgs": "-Dfabric.dli.config\u003d${workspaceFolder}\\fabric\\.gradle\\loom-cache\\launch.cfg -Dfabric.dli.env\u003dclient -Xms1G -Xmx3G -Dfabric.dli.main\u003dnet.fabricmc.loader.impl.launch.knot.KnotClient -Darchitectury.main.class\u003d${workspaceFolder}\\fabric\\.gradle\\architectury\\.main_class -Darchitectury.runtime.transformer\u003d${workspaceFolder}\\fabric\\.gradle\\architectury\\.transforms -Darchitectury.properties\u003d${workspaceFolder}\\fabric\\.gradle\\architectury\\.properties -Djdk.attach.allowAttachSelf\u003dtrue -javaagent:${workspaceFolder}\\.gradle\\architectury\\architectury-transformer-agent.jar",
      "args": "",
      "env": {},
      "projectName": "fabric"
    },
    {
      "type": "java",
      "name": "Minecraft Server (:fabric)",
