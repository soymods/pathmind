    {
      "id": "tutorial-3-note-data",
      "type": "STICKY_NOTE",
      "x": 160,
      "y": -210,
      "parameters": [],
      "parameterAttachments": [],
      "stickyNoteText": "DATA PIPELINE\nCreate List starts a runtime list named team with Self, Add to List appends another entry, and List Length is saved as memberCount. Calculate can create several named outputs in order, so later expressions can use earlier ones.",
      "stickyNoteWidth": 1090,
      "stickyNoteHeight": 130
    },
    {
      "id": "tutorial-3-note-parallel",
      "type": "STICKY_NOTE",
      "x": 1450,
      "y": -250,
      "parameters": [],
      "parameterAttachments": [],
      "stickyNoteText": "PARALLEL PIPELINE\nFork launches both outputs concurrently. Each branch arrives at a different Join All input. Execution after Join All waits until both inputs have arrived, so the slower 0.75-second branch controls when the graph continues.",
      "stickyNoteWidth": 1030,
      "stickyNoteHeight": 125
    },
    {
      "id": "tutorial-3-note-functions",
      "type": "STICKY_NOTE",
      "x": 1110,
      "y": 390,
      "parameters": [],
      "parameterAttachments": [],
      "stickyNoteText": "FUNCTIONS\nEvent Call runs the matching Event Function branch and waits for it to finish. Functions share this execution scope, so their messages can read memberCount, workUnits, target, and score with $variable syntax.",
      "stickyNoteWidth": 1940,
      "stickyNoteHeight": 105
    }
  ],
